{
  "name": "@brainminds-dataportal/vol-renderer",
  "repository": {
    "type": "git",
    "url": "https://github.com/brainminds-dataportal/vol-renderer.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "0.1.0",
  "description": "",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "style": "dist/main.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./dist/main.css": "./dist/main.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run rollup",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "demo:build": "npm --prefix demo-app run build",
    "demo:dev": "npm --prefix demo-app run dev",
    "demo:preview": "npm --prefix demo-app run preview",
    "demo:sync": "npm run demo:build && node scripts/sync-demo-app-build.mjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "rollup": "npm run build:types && rollup --config"
  },
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.184.0",
    "postcss": "^8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-sass": "^1.15.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.12.1",
    "@blueprintjs/popover2": "^2.1.32",
    "@tweenjs/tween.js": "^25.0.0",
    "fflate": "^0.8.2",
    "jotai": "^2.19.1",
    "nifti-reader-js": "^0.8.0",
    "three": "^0.184.0"
  },
  "peerDependencies": {
    "normalize.css": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
